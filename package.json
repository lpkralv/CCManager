{
  "name": "claude-code-manager",
  "version": "0.1.0",
  "description": "Knowledge repository and management tools for Claude Code projects",
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "start:electron": "electron .",
    "build:mac": "npm run build && electron-builder --mac"
  },
  "keywords": [
    "claude",
    "code",
    "manager",
    "inventory"
  ],
  "author": "lpkralv",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "uuid": "^9.0.0",
    "ws": "^8.16.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "build": {
    "appId": "com.lpkralv.claudecodemanager",
    "productName": "ClaudeCodeManager",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dir"
    },
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "data/**/*",
      "node_modules/**/*"
    ]
  }
}
